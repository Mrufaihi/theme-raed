{% set logos = [
    'whitecbs.svg',
    'whitenbc.svg',
    'whitenational.svg',
    'whiteforbes.svg',
    'whiteusatoday.svg',
    'whitecut.svg',
    'whitestrandard.svg',
    'whitetodaysshow.svg'
] %}

<section class="bg-primary py-8" id="jawliner-logos">
    <div class="p-4 flex flex-col gap-3 justify-center items-center w-full">
        <div class="flex gap-2">
            <h2 class="text-center text-2xl lg:text-4xl font-bold text-white mb-1">منتج مذكور</h2>
            <h2 class="text-center text-2xl lg:text-4xl font-bold text-white mb-1">في</h2>
        </div>
        <div class="h-[60px] md:h-[90px] shadow-sm flex items-center overflow-hidden w-full" dir="ltr">
            <div class="logo-slider flex gap-12 md:gap-24">
                {% for _ in 1..3 %}
                    {% for logo in logos %}
                        <img
                            src="{{ ('images/jawliner/Logos/' ~ logo) | asset }}"
                            alt=""
                            class="h-[60px] flex-shrink-0"
                            loading="lazy"
                        />
                    {% endfor %}
                {% endfor %}
            </div>
        </div>
    </div>
</section>
